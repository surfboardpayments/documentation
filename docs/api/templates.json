        {
            "heading": "Create Template",
            "description": "This API allows you to create a new POS template.",
            "reqParams": [
                {
                    "name": "paymentMethodOrder",
                    "type": "array",
                    "description": "Array of preferred payment methods that will be displayed on the POS system in the order of preference."
                },
                {
                    "name": "name",
                    "type": "string",
                    "mandatory": true,
                    "description": "Name or label for the POS template."
                },
                {
                    "name": "productsPerPage",
                    "type": "number",
                    "description": "Number of products to be displayed per page in the POS template."
                },
                {
                    "name": "product",
                    "type": "array",
                    "description": "Product categories and their order.",
                    "reqParams": [
                        {
                            "name": "category",
                            "type": "string",
                            "mandatory": true,
                            "description": "Category of the product."
                        },
                        {
                            "name": "productOrder",
                            "type": "array",
                            "mandatory": true,
                            "description": "Array of product IDs in the preferred order."
                        }
                    ]
                },
                {
                    "name": "autoSet",
                    "type": "array",
                    "description": "Array of time intervals during which certain automatic settings or actions should be applied.",
                    "reqParams": [
                        {
                            "name": "start",
                            "type": "string",
                            "mandatory": true,
                            "description": "Start time for the interval."
                        },
                        {
                            "name": "end",
                            "type": "string",
                            "mandatory": true,
                            "description": "End time for the interval."
                        }
                    ]
                },
                {
                    "name": "terminal",
                    "type": "object",
                    "description": "Terminal information for the POS template.",
                    "reqParams": [
                        {
                            "name": "primaryTerminal",
                            "type": "string",
                            "description": "ID of the primary terminal to be used."
                        },
                        {
                            "name": "secondaryTerminal",
                            "type": "string",
                            "description": "ID of the secondary terminal to be used."
                        },
                        {
                            "name": "terminalOrder",
                            "type": "array",
                            "description": "Array of terminal IDs in the preferred order."
                        }
                    ]
                },
                {
                    "name": "metaData",
                    "type": "object",
                    "description": "Additional metadata for the POS template as key-value pairs."
                }
            ],
            "resParams": [
                {
                    "name": "status",
                    "type": "string",
                    "mandatory": true,
                    "description": "Status of the request."
                },
