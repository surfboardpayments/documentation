{
    "title": "Electronic Cash Register (ECR) V2 API",
    "description": "The ECR V2 API enables merchants to manage electronic cash registers for daily operations. This includes subscribing cash registers, opening/closing registers and shifts, managing cash deposits and withdrawals, and tracking register state. The API follows a sequential flow matching natural business day operations.",
    "endpoints": [
        {
            "fragment": "Subscribe to Cash Register",
            "method": "POST",
            "link": "API_URL/merchants/:merchantId/stores/:storeId/cash-register"
        },
        {
            "fragment": "Open Cash Register",
            "method": "PUT",
            "link": "API_URL/merchants/:merchantId/stores/:storeId/cash-register/open"
        },
        {
            "fragment": "Fetch Cash Register State",
            "method": "GET",
            "link": "API_URL/merchants/:merchantId/stores/:storeId/terminals/:terminalId/cash-register/state-info"
        },
        {
            "fragment": "Open Shift",
            "method": "PUT",
            "link": "API_URL/merchants/:merchantId/stores/:storeId/cash-register/shift/open"
        },
        {
            "fragment": "Deposit Cash",
            "method": "PUT",
            "link": "API_URL/merchants/:merchantId/stores/:storeId/cash-register/deposit"
        },
        {
            "fragment": "Withdraw Cash",
            "method": "PUT",
            "link": "API_URL/merchants/:merchantId/stores/:storeId/cash-register/withdraw"
        },
        {
            "fragment": "Close Shift",
            "method": "PUT",
            "link": "API_URL/merchants/:merchantId/stores/:storeId/cash-register/shift/close"
        },
        {
            "fragment": "Close Cash Register",
            "method": "PUT",
            "link": "API_URL/merchants/:merchantId/stores/:storeId/cash-register/close"
        },
        {
            "fragment": "Fetch Cash Registers",
            "method": "GET",
            "link": "API_URL/merchants/:merchantId/cash-register"
        },
        {
            "fragment": "Fetch Available Cash Registers",
            "method": "GET",
            "link": "API_URL/merchants/:merchantId/stores/:storeId/cash-register/available"
        }
    ],
    "apis": [
        {
            "heading": "Subscribe to Cash Register",
            "type": "note",
            "note": "For testing in sandbox environments, use the demo endpoint: <span class='font-semibold'>/merchants/:merchantId/stores/:storeId/cash-register/demo</span>",
            "description": "Register a terminal as an Electronic Cash Register (ECR) for a specific store.",
            "reqParams": [
                {
                    "name": "cashRegisterName",
                    "type": "string",
                    "mandatory": true,
                    "description": "Name of the cash register"
                },
                {
                    "name": "deviceId",
                    "type": "string",
                    "mandatory": true,
                    "description": "Terminal / device identifier"
                },
                {
                    "name": "emails",
                    "type": "array",
                    "mandatory": false,
                    "description": "List of email addresses for notifications"
                }
            ],
            "resParams": [
                {
                    "name": "status",
                    "type": "string",
                    "mandatory": true,
                    "description": "Status of the request"
                },
                {
                    "name": "data",
                    "type": "object",
                    "mandatory": true,
                    "description": "Response data",
                    "resParams": [
                        {
                            "name": "cashRegister",
                            "type": "object",
                            "mandatory": true,
                            "description": "Cash register details",
                            "resParams": [
                                {
                                    "name": "cashRegisterId",
                                    "type": "string",
                                    "mandatory": true,
                                    "description": "Unique identifier for the cash register. Save this ID as it is required for opening the register and shifts."
                                }
                            ]
                        }
                    ]
                },
                {
                    "name": "message",
                    "type": "string",
                    "mandatory": true,
                    "description": "Response message"
                }
            ],
            "method": "POST",
            "path": "/merchants/:merchantId/stores/:storeId/cash-register",
            "examples": {
                "request": {
                    "headers": [
                        {
                            "name": "Content-Type",
                            "value": "application/json"
                        },
                        {
                            "name": "API-KEY",
                            "value": "YOUR_API_KEY"
                        },
                        {
                            "name": "API-SECRET",
                            "value": "YOUR_API_SECRET"
                        },
                        {
                            "name": "MERCHANT-ID",
                            "value": "YOUR_MERCHANT_ID"
                        }
                    ],
                    "body": "{\"cashRegisterName\":\"Main Register\",\"deviceId\":\"{{terminalId}}\",\"emails\":[\"store.manager@example.com\"]}"
                },
                "response": [
                    {
                        "code": 201,
                        "response": "\n{\n\t\"status\":\"SUCCESS\",\n\t\"data\":{\n\t\t\"cashRegister\":{\n\t\t\t\"cashRegisterId\":\"{{cashRegisterId}}\"\n\t\t}\n\t},\n\t\"message\":\"Cash register subscribed successfully\"\n}"
                    }
                ]
            }
        },
        {
            "heading": "Open Cash Register",
            "description": "Open the cash register at the start of the business day with an initial petty cash amount. You can optionally open a shift in the same request by setting openShift to true.",
            "reqParams": [
                {
                    "name": "cashRegisterId",
                    "type": "string",
                    "mandatory": true,
                    "description": "Cash Register ID obtained from subscription"
                },
                {
                    "name": "terminalId",
                    "type": "string",
                    "mandatory": true,
                    "description": "Terminal / device identifier"
                },
                {
                    "name": "pettyCash",
                    "type": "number",
                    "mandatory": true,
                    "description": "Opening cash amount (maximum 15,000 SEK)"
                },
                {
                    "name": "currencyCode",
                    "type": "string",
                    "mandatory": true,
                    "description": "Currency code (e.g., SEK)"
                },
                {
                    "name": "openShift",
                    "type": "boolean",
                    "mandatory": false,
                    "description": "Set to true to open a shift automatically"
                },
                {
                    "name": "cashierName",
                    "type": "string",
                    "mandatory": false,
                    "description": "Name of the cashier"
                }
            ],
            "resParams": [
                {
                    "name": "status",
                    "type": "string",
                    "mandatory": true,
                    "description": "Status of the request"
                },
                {
                    "name": "data",
                    "type": "object",
                    "mandatory": true,
                    "description": "Response data",
                    "resParams": [
                        {
                            "name": "cashRegisterId",
                            "type": "string",
                            "mandatory": true,
                            "description": "Cash register identifier"
                        },
                        {
                            "name": "pettyCash",
                            "type": "number",
                            "mandatory": true,
                            "description": "Opening cash amount"
                        },
                        {
                            "name": "currencyCode",
                            "type": "string",
                            "mandatory": true,
                            "description": "Currency code"
                        },
                        {
                            "name": "cashierName",
                            "type": "string",
                            "mandatory": false,
                            "description": "Name of the cashier"
                        }
                    ]
                },
                {
                    "name": "message",
                    "type": "string",
                    "mandatory": true,
                    "description": "Response message"
                }
            ],
            "method": "PUT",
            "path": "/merchants/:merchantId/stores/:storeId/cash-register/open",
            "examples": {
                "request": {
                    "headers": [
                        {
                            "name": "Content-Type",
                            "value": "application/json"
                        },
                        {
                            "name": "API-KEY",
                            "value": "YOUR_API_KEY"
                        },
                        {
                            "name": "API-SECRET",
                            "value": "YOUR_API_SECRET"
                        },
                        {
                            "name": "MERCHANT-ID",
                            "value": "YOUR_MERCHANT_ID"
                        }
                    ],
                    "body": "{\"cashRegisterId\":\"{{cashRegisterId}}\",\"terminalId\":\"{{terminalId}}\",\"pettyCash\":5000,\"currencyCode\":\"SEK\",\"openShift\":true,\"cashierName\":\"John Doe\"}"
                },
                "response": [
                    {
                        "code": 200,
                        "response": "\n{\n\t\"status\":\"SUCCESS\",\n\t\"data\":{\n\t\t\"cashRegisterId\":\"{{cashRegisterId}}\",\n\t\t\"pettyCash\":5000,\n\t\t\"currencyCode\":\"SEK\",\n\t\t\"cashierName\":\"John Doe\"\n\t},\n\t\"message\":\"Cash register opened successfully\"\n}"
                    }
                ]
            }
        },
        {
            "heading": "Fetch Cash Register State",
            "description": "Retrieve the current state of the cash register, including shift details and operational status. This helps ensure the register is ready before performing operations.",
            "reqParams": [],
            "resParams": [
                {
                    "name": "status",
                    "type": "string",
                    "mandatory": true,
                    "description": "Status of the request"
                },
                {
                    "name": "data",
                    "type": "object",
                    "mandatory": true,
                    "description": "Response data",
                    "resParams": [
                        {
                            "name": "cashRegisterState",
                            "type": "string",
                            "mandatory": true,
                            "description": "Current state of the cash register",
                            "possibleValues": [
                                {
                                    "value": "CASH_REGISTER_OPEN",
                                    "description": "Register is open and operational"
                                },
                                {
                                    "value": "CASH_REGISTER_CLOSED",
                                    "description": "Register is closed"
                                }
                            ]
                        },
                        {
                            "name": "currencyCode",
                            "type": "string",
                            "mandatory": true,
                            "description": "Currency in which the register operates"
                        },
                        {
                            "name": "shiftInfo",
                            "type": "object",
                            "mandatory": true,
                            "description": "Current shift information",
                            "resParams": [
                                {
                                    "name": "shiftNumber",
                                    "type": "number",
                                    "mandatory": true,
                                    "description": "Current shift number"
                                },
                                {
                                    "name": "shiftState",
                                    "type": "string",
                                    "mandatory": true,
                                    "description": "Current state of the shift",
                                    "possibleValues": [
                                        {
                                            "value": "SHIFT_OPEN",
                                            "description": "Shift is currently active"
                                        },
                                        {
                                            "value": "SHIFT_CLOSED",
                                            "description": "No active shift"
                                        }
                                    ]
                                },
                                {
                                    "name": "cashierName",
                                    "type": "string",
                                    "mandatory": false,
                                    "description": "Name of the active cashier"
                                },
                                {
                                    "name": "shiftOpenedAt",
                                    "type": "string",
                                    "mandatory": true,
                                    "description": "Timestamp when the shift started"
                                }
                            ]
                        },
                        {
                            "name": "pettyCash",
                            "type": "number",
                            "mandatory": true,
                            "description": "Opening cash amount in the register"
                        },
                        {
                            "name": "openedAt",
                            "type": "string",
                            "mandatory": true,
                            "description": "Timestamp when the register was opened"
                        }
                    ]
                },
                {
                    "name": "message",
                    "type": "string",
                    "mandatory": true,
                    "description": "Response message"
                }
            ],
            "method": "GET",
            "path": "/merchants/:merchantId/stores/:storeId/terminals/:terminalId/cash-register/state-info",
            "examples": {
                "request": {
                    "headers": [
                        {
                            "name": "API-KEY",
                            "value": "YOUR_API_KEY"
                        },
                        {
                            "name": "API-SECRET",
                            "value": "YOUR_API_SECRET"
                        },
                        {
                            "name": "MERCHANT-ID",
                            "value": "YOUR_MERCHANT_ID"
                        }
                    ]
                },
                "response": [
                    {
                        "code": 200,
                        "response": "\n{\n\t\"status\":\"SUCCESS\",\n\t\"data\":{\n\t\t\"cashRegisterState\":\"CASH_REGISTER_OPEN\",\n\t\t\"currencyCode\":\"SEK\",\n\t\t\"shiftInfo\":{\n\t\t\t\"shiftNumber\":1,\n\t\t\t\"shiftState\":\"SHIFT_OPEN\",\n\t\t\t\"cashierName\":\"John Doe\",\n\t\t\t\"shiftOpenedAt\":\"2026-04-15T12:00:00Z\"\n\t\t},\n\t\t\"pettyCash\":5000,\n\t\t\"openedAt\":\"2026-04-15T08:00:00Z\"\n\t},\n\t\"message\":\"Cash register state fetched successfully\"\n}"
                    }
                ]
            }
        },
        {
