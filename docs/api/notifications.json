                                },
                                {
                                    "name": "user",
                                    "type": "string",
                                    "description": "SFTP username"
                                },
                                {
                                    "name": "port",
                                    "type": "number",
                                    "description": "SFTP port number"
                                },
                                {
                                    "name": "publicKey",
                                    "type": "string",
                                    "description": "SFTP public key"
                                },
                                {
                                    "name": "separator",
                                    "type": "string",
                                    "description": "CSV field separator"
                                }
                            ]
                        },
                        {
                            "name": "status",
                            "type": "string",
                            "description": "Status of the notification subscription"
                        }
                    ]
                },
                {
                    "name": "message",
                    "type": "string",
                    "mandatory": true,
                    "description": "A message that describes the status of the request"
                }
            ],
            "method": "GET",
            "path": "/merchants/:merchantId/notifications",
            "examples": {
                "request": {
                    "headers": [
                        {
                            "name": "Content-Type",
                            "value": "application/json"
                        },
                        {
                            "name": "API-KEY",
