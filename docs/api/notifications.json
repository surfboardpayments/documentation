{
    "title": "Notifications API",
    "description": "The Notifications API enables merchants and partners to subscribe to event notifications via SFTP or email. It allows you to configure automated notifications for various events and manage your notification subscriptions.",
    "endpoints": [
        {
            "fragment": "Subscribe to Merchant Reports",
            "method": "POST",
            "link": "API_URL/merchants/:merchantId/notifications/reports"
        },
        {
            "fragment": "Fetch External Notifications for Merchant",
            "method": "GET",
            "link": "API_URL/merchants/:merchantId/notifications"
        },
        {
            "fragment": "Unsubscribe Notification for Merchant",
            "method": "DELETE",
            "link": "API_URL/merchants/:merchantId/notifications/:notificationId"
        },
        {
            "fragment": "Subscribe to Partner Notification",
            "method": "POST",
            "link": "API_URL/partners/:partnerId/notifications/reports"
        },
        {
            "fragment": "Fetch External Notifications for Partner",
            "method": "GET",
            "link": "API_URL/partners/:partnerId/notifications"
        },
        {
            "fragment": "Unsubscribe Notifications for Partner",
            "method": "DELETE",
            "link": "API_URL/partners/:partnerId/notifications/:notificationId"
        }
    ],
    "apis": [
        {
            "heading": "Subscribe to Merchant Reports",
            "description": "Subscribe to receive automated notifications for merchant events. You must provide at least one notification channel: email, slackUrl, or sftpInfo to create a notification subscription. This endpoint supports multiple notification channels including EMAIL, SLACK, and SFTP.",
            "new": true,
            "reqParams": [
                {
                    "name": "event",
                    "type": "string",
                    "mandatory": true,
                    "description": "The event type to subscribe to for notifications",
                    "possibleValues": [
                        {
                            "value": "DAILY_REPORTS",
                            "description": "Daily merchant reports"
                        },
                        {
                            "value": "MONTHLY_REPORTS",
                            "description": "Monthly merchant reports"
                        },
                        {
                            "value": "PAYMENT_COMPLETED",
                            "description": "Payment completion notifications"
                        },
                        {
                            "value": "DAILY_FILE_TRANSFER",
                            "description": "Daily SFTP file transfers"
                        },
                        {
                            "value": "WEEKLY_FILE_TRANSFER",
                            "description": "Weekly SFTP file transfers"
                        },
                        {
                            "value": "MONTHLY_FILE_TRANSFER",
                            "description": "Monthly SFTP file transfers"
                        }
                    ]
                },
                {
                    "name": "email",
                    "type": "string",
                    "mandatory": false,
                    "description": "Email address for notification delivery (optional)",
                    "conditional": true
                },
                {
                    "name": "slackUrl",
                    "type": "string",
                    "mandatory": false,
                    "description": "Slack webhook URL for notification delivery (optional)",
                    "conditional": true
                },
                {
                    "name": "sftpInfo",
                    "type": "object",
                    "mandatory": false,
                    "description": "SFTP configuration for receiving notification reports",
                    "conditional": true,
                    "reqParams": [
                        {
                            "name": "host",
                            "type": "string",
                            "mandatory": true,
                            "description": "SFTP server hostname or IP address"
                        },
                        {
                            "name": "user",
                            "type": "string",
                            "mandatory": true,
                            "description": "Username for SFTP authentication"
                        },
                        {
                            "name": "port",
                            "type": "number",
                            "mandatory": false,
                            "description": "SFTP server port (default: 22)"
                        },
                        {
                            "name": "hostKey",
                            "type": "string",
                            "mandatory": false,
                            "description": "SFTP server host key for secure connection"
                        },
                        {
                            "name": "remoteDirectory",
                            "type": "string",
                            "mandatory": false,
                            "description": "Remote directory path for file delivery"
                        },
                        {
                            "name": "separator",
                            "type": "string",
                            "mandatory": false,
                            "description": "Field separator for CSV reports",
                            "possibleValues": [
                                {
                                    "value": "COMMA",
                                    "description": "Comma separator (,)"
                                },
                                {
                                    "value": "SEMICOLON",
                                    "description": "Semicolon separator (;)"
                                },
                                {
                                    "value": "PIPE",
                                    "description": "Pipe separator (|)"
                                },
                                {
                                    "value": "TAB",
                                    "description": "Tab separator"
                                }
                            ]
                        }
                    ]
                }
            ],
            "resParams": [
                {
                    "name": "status",
                    "type": "string",
                    "mandatory": true,
                    "description": "Status of the request, indicated as either 'SUCCESS' or 'ERROR'"
                },
                {
                    "name": "data",
                    "type": "array",
                    "mandatory": true,
                    "description": "Array of notification subscription data",
                    "resParams": [
                        {
                            "name": "notificationId",
                            "type": "string",
                            "mandatory": true,
                            "description": "Unique identifier for the notification subscription"
                        },
                        {
                            "name": "NotificationChannel",
                            "type": "string",
                            "mandatory": true,
                            "description": "Type of notification channel (e.g., SLACK, SFTP, EMAIL)"
                        },
                        {
                            "name": "publicKey",
                            "type": "string",
                            "mandatory": false,
                            "description": "Public key for SFTP authentication (only present for SFTP channels)"
                        }
                    ]
                },
                {
                    "name": "message",
                    "type": "string",
                    "mandatory": true,
                    "description": "A message that describes the status of the request"
                }
            ],
            "method": "POST",
            "path": "/merchants/:merchantId/notifications/reports",
            "examples": {
                "request": {
                    "headers": [
                        {
                            "name": "Content-Type",
                            "value": "application/json"
                        },
                        {
                            "name": "API-KEY",
                            "value": "YOUR_API_KEY"
                        },
                        {
                            "name": "API-SECRET",
                            "value": "YOUR_API_SECRET"
                        },
                        {
                            "name": "MERCHANT-ID",
                            "value": "YOUR_MERCHANT_ID"
                        }
                    ],
                    "body": "{\n  \"event\": \"DAILY_FILE_TRANSFER\",\n  \"slackUrl\": \"https://surfboardworkspace.slack.com/archives/C039RL0LS8M\",\n  \"email\": \"john@gmail.com\",\n  \"sftpInfo\": {\n    \"host\": \"192.168.0.211\",\n    \"user\": \"surfboard-test\",\n    \"port\": 8080,\n    \"hostKey\": \"\"\n  }\n}"
                },
                "response": [
                    {
                        "code": 201,
                        "response": "{\n  \"status\": \"SUCCESS\",\n  \"data\": [\n    {\n      \"notificationId\": \"839dd1b8113ff809f3\",\n      \"NotificationChannel\": \"EMAIL\"\n    },\n    {\n      \"notificationId\": \"839dd1b8113ff819f3\",\n      \"NotificationChannel\": \"SLACK\"\n    },\n    {\n      \"notificationId\": \"839dd1b8113ff82af3\",\n      \"NotificationChannel\": \"SFTP\",\n      \"publicKey\": \"ssh-rsa  surfboard-test@34.88.179.4\"\n    }\n  ],\n  \"message\": \"External notification for MERCHANT_ID: m_iWGri3XAyTmkbKYsYtV47 registered successfully\"\n}"
                    }
                ]
            }
        },
        {
