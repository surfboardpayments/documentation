{
    "scenarioId": "create-service-provider",
    "scenarioName": "Create Service Provider",
    "steps": [
        {
            "id": "create-service-provider",
            "name": "Create Service Provider",
            "description": "Create Service Provider",
            "order": 1,
            "method": "POST",
            "endpoint": "partners/{{partnerId}}/service-providers",
            "guidePath": "/carbon/added-features/create-service-provider",
            "payload": {
                "country": "SE",
                "organisation": {
                    "corporateId": "3532007322"
                },
                "controlFields": {
                    "isServiceProvider": true
                }
            },
            "specifications": {
                "reqParams": [
                    {
                        "name": "country",
                        "type": "string",
                        "mandatory": true,
                        "description": "Two-letter ISO country code where the service provider operates."
                    },
                    {
                        "name": "organisation",
                        "type": "object",
                        "mandatory": true,
                        "description": "Organization details for the service provider.",
                        "reqParams": [
                            {
                                "name": "corporateId",
                                "type": "string",
                                "mandatory": true,
                                "description": "Corporate identification number of the organization."
                            }
                        ]
                    },
                    {
                        "name": "controlFields",
                        "type": "object",
