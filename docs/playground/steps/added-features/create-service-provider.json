                        "resParams": [
                            {
                                "name": "applicationId",
                                "type": "string",
                                "mandatory": true,
                                "description": "Unique identifier for the created service provider application."
                            },
                            {
                                "name": "webKybUrl",
                                "type": "string",
                                "mandatory": true,
                                "description": "URL for the web-based KYB (Know Your Business) process."
                            }
                        ]
                    },
                    {
                        "name": "message",
                        "type": "string",
                        "mandatory": true,
                        "description": "A message that describes the status of the request."
                    }
                ]
            }
        }
    ]
