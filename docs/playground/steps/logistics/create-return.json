                                    {
                                        "name": "number",
                                        "type": "string",
                                        "mandatory": true,
                                        "description": "Phone number."
                                    }
                                ]
                            },
                            {
                                "name": "addressLine1",
                                "type": "string",
                                "mandatory": true,
