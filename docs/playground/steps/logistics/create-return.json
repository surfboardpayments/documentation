            "description": "Returns devices (terminals and other accessories) to Surfboard once its malfunctioning or damaged",
            "order": 1,
            "method": "POST",
            "endpoint": "partners/{{partnerId}}/logistics/returns",
            "readOnly": true,
            "response": {
                "status": "SUCCESS",
                "data": {
                    "returnId": 80
                },
                "message": "Return request created successfully"
            },
            "guidePath": "/carbon/logistics/device-returning/create-return/home",
            "payload": {
                "merchantInfo": {
                    "name": "Demo Store",
                    "email": "demo@example.com",
                    "phoneNumber": {
                        "code": "46",
                        "number": "123456789"
                    },
                    "addressLine1": "Demo Street 123",
                    "addressLine2": "Building A",
                    "addressLine3": null,
                    "city": "Stockholm",
                    "countryCode": "SE",
                    "postalNumber": "12345"
                },
                "returnOrderLines": [
                    {
                        "serial": "TERM001234567",
                        "terminalId": "816a0ff6bc0fb00404",
                        "reasonForReturn": "NOT_USING_SERVICE",
