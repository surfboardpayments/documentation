                                "name": "postalNumber",
                                "type": "string",
                                "mandatory": true,
                                "description": "Postal code of the merchant's address."
                            },
                            {
                                "name": "city",
                                "type": "string",
                                "mandatory": true,
                                "description": "City of the merchant's address."
                            }
                        ]
                    },
                    {
                        "name": "returnOrderLines",
                        "type": "array",
