{
    "scenarioId": "create-branding-for-merchant",
    "scenarioName": "Create Branding for Merchant",
    "steps": [
        {
            "id": "create-branding-for-merchant",
            "name": "Create Branding for Merchant",
            "description": "Set branding configurations for all the terminals registered to a specific merchant.",
            "order": 1,
            "method": "PATCH",
            "endpoint": "merchants/{{merchantId}}/branding",
            "guidePath": "/carbon/configure-branding/merchant-level/home",
            "readOnly": true,
            "response": {
                "status": "SUCCESS",
                "message": "Branding configuration set successfully."
              },
            "payload": {
                "backgroundColor": "#667085",
                "brandColor": "#697085",
                "accentColor": "#787085",
                "rectShape": "rounded",
                "fontType": "sans-serif",
                "logoUrl": "https://res.cloudinary.com/image/surfboard-icon.svg",
                "iconUrl": "https://res.cloudinary.com/image/surfboard-icon.svg",
                "footerColor": "#CD5C5B",
                "primaryCoverImage": "https://images.app.goo.gl/PxBcTVm4Q1xJFhCn6",
                "secondaryCoverImage": "https://images.app.goo.gl/PxBcTVm4Q1xJFhCn6"
              },
            "specifications": {
                "reqParams": [
                        {
                            "name": "backgroundColor",
                            "type": "string",
                            "mandatory": false,
                            "description": "Background color for the page."
                        },
