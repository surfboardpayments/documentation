{
    "scenarioId": "get-gift-card-details",
    "scenarioName": "Get Gift Card Details",
    "steps": [
        {
            "id": "get-gift-card-details",
            "name": "Get Gift Card Details",
            "description": "Get details of a specific gift card.",
            "order": 1,
            "method": "GET",
            "endpoint": "gift-cards/{{id}}",
            "guidePath": "/carbon/advanced-customizations/get-gift-card-details",
            "payload": {},
