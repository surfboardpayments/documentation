                                "type": "array",
                                "description": "Array of sub-charges associated with this main charge.",
                                "resParams": [
                                    {
                                        "name": "chargeId",
                                        "type": "string",
                                        "description": "Unique identifier for this sub-charge."
                                    },
                                    {
                                        "name": "description",
                                        "type": "string",
                                        "description": "A short text describing the sub-charge."
                                    },
                                    {
                                        "name": "amount",
                                        "type": "number",
